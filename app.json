{
  "expo": {
    "name": "Springs of Joy",
    "slug": "springs-of-joy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo-Components.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/StartupImage.png",
      "resizeMode": "contain",
      "backgroundColor": "#005F3A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.musdaa.springsoffoy"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo-Components.png",
        "backgroundColor": "#005F3A"
      },
      "package": "com.musdaa.springsofjoyhymnal"
    },
    "web": {
      "favicon": "./assets/Logo-Components.png"
    }
  }
}
